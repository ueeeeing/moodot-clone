# LLM 프로바이더 선택: "openai" 또는 "ollama" (기본값: ollama)
LLM_PROVIDER=openai

# OpenAI (LLM_PROVIDER=openai 일 때 필수)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Ollama (LLM_PROVIDER=ollama 일 때 사용)
# OLLAMA_MODEL=qwen2.5:latest
# OLLAMA_BASE_URL=http://localhost:11434

# Supabase (서비스 롤 키 — RLS 우회 필요)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# 메모리 텍스트 복호화 키 (Next.js 앱과 동일한 값)
MEMORY_TEXT_ENCRYPTION_KEY=your-32-byte-key-here

# 서버 포트 (기본값: 8000)
PORT=8000
